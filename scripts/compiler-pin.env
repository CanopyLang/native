# compiler-pin.env — the single auditable source of truth for which sibling Canopy
# compiler commit canopy/native builds its JS bundle with (CI-2). Sourced by
# scripts/build-compiler-from-pin.sh and referenced by docs/compiler-pinning.md.
#
# Bumping the pin is a ONE-LINE edit here (CANOPY_COMPILER_SHA) + a commit; CI then
# rebuilds the compiler from the new SHA reproducibly and re-runs the F7 gate.
# The SHA MUST include the CMP-1/2/3 tree-shaker + resolver fixes (see
# docs/compiler-fixes.md), otherwise the IIFE bundle throws `F7 is not defined`.

# Pinned commit of the in-house compiler. Wave-1 master tip that lands the
# tree-shaker root-scan (scanRuntimeIdents/scanArities) + PackageCache.resolveInstalledVersion.
CANOPY_COMPILER_SHA=391dde943a793ad03c0b394a2f64396cf11252d4

# Remote the SHA is fetched from on a clean CI runner / fresh dev box (no sibling clone).
CANOPY_COMPILER_REMOTE=https://github.com/CanopyLang/compiler.git

# Branch the SHA lives on (informational; the build pins the SHA, not the branch).
CANOPY_COMPILER_BRANCH=master

# Canonical app whose IIFE bundle is the F7 acceptance proof. `canopy-native build`
# emits build/canopy.bundle.js (preamble + compiled IIFE + boot hook). examples/echo
# in the source plan is stale (lower-bound deps + a dangling virtual-dom source dir);
# counter is the live, harness-backed app the renderer gate already drives.
CANOPY_PIN_CANONICAL_APP=examples/counter
