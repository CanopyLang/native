{
    "type": "package",
    "name": "canopy/native",
    "summary": "Build native iOS/Android apps from Canopy view code, rendering through React Native's Fabric over JSI \u2014 no React, no WebView",
    "license": "BSD-3-Clause",
    "version": "0.1.0",
    "exposed-modules": [
        "Native",
        "Native.Animated",
        "Native.Attributes",
        "Native.Events",
        "Native.BeforeAfter",
        "Native.Controls",
        "Native.Css",
        "Native.Http",
        "Native.List",
        "Native.List.Window",
        "Native.Modal",
        "Native.Module",
        "Native.Platform",
        "Native.Scroll",
        "Native.StatusBar",
        "Native.Testing",
        "Native.Vibration",
        "Native.Battery",
        "Native.DeviceInfo",
        "Native.NetInfo",
        "Native.Haptics",
        "Native.Brightness"
    ],
    "canopy-version": "0.19.0 <= v < 0.20.0",
    "dependencies": {
        "canopy/core": "1.0.0 <= v < 2.0.0",
        "canopy/css": "1.0.0 <= v < 2.0.0",
        "canopy/json": "1.0.0 <= v < 2.0.0",
        "canopy/virtual-dom": "1.0.0 <= v < 2.0.0"
    },
    "test-dependencies": {
        "canopy/test": "1.0.0 <= v < 3.0.0"
    }
}