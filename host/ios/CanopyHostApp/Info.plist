<?xml version="1.0" encoding="UTF-8"?>
<!--
  Info.plist — Canopy iOS host app (Author A, SHARED CONTRACT §1 / §2.1).

  Carries the capability usage-description strings the §5 modules require (the app crashes at
  the point of first use if a string is missing). Each string is paired with the Swift module
  that triggers the prompt:
    • NSPhotoLibraryAddUsageDescription      -> AlbumModule (PHPhotoLibrary add-only save)
    • NSPhotoLibraryUsageDescription         -> (only if a module ever reads the library; PHPicker
                                                 itself does NOT require it — kept minimal/absent
                                                 by default; add back only if a read path appears)
    • NSUserNotificationsUsageDescription    -> NotifyModule (UNUserNotificationCenter)  [advisory]
  StoreKit 2 (BillingModule) needs no usage string; it needs the in-app-purchase entitlement
  (CanopyHost.entitlements) and a .storekit config / sandbox account.

  The launch sequence: SceneDelegate sets CanopyHostViewController as the window root (§3.6).
  The bundle (canopy.bundle.js) + Core ML model are copied into Resources by the build phase.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>$(DEVELOPMENT_LANGUAGE)</string>
    <key>CFBundleDisplayName</key>
    <string>Canopy</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>$(PRODUCT_NAME)</string>
    <key>CFBundlePackageType</key>
    <string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
    <key>CFBundleShortVersionString</key>
    <string>$(MARKETING_VERSION)</string>
    <key>CFBundleVersion</key>
    <string>$(CURRENT_PROJECT_VERSION)</string>

    <!-- ===== Capability usage strings (§5) ===== -->
    <key>NSPhotoLibraryAddUsageDescription</key>
    <string>Canopy saves restored and edited photos to your library.</string>
    <key>NSCameraUsageDescription</key>
    <string>Canopy can use the camera to capture a photo to restore.</string>

    <!-- ===== App Transport Security (DEV-12 dev-loop exception + IOS-10 production posture) =====
         App Transport Security is ENFORCED for the shipped (release/archive) build: there is NO
         NSAllowsArbitraryLoads and NO blanket cleartext exception, so every production network call
         (HttpModule, BillingModule/StoreKit, NotifyModule/APNs) must be HTTPS with a modern TLS
         posture — the App Store-review-clean default (IOS-10).

         The ONE scope present is NSAllowsLocalNetworking, the iOS platform-layer analogue of
         Android's debug-only res/xml/network_security_config.xml: it permits cleartext ONLY to
         local-network hosts (loopback / LAN), never to a public host on the internet. It exists for
         the debug-only CanopyDevClient, which dials the dev server over cleartext ws:// (no TLS in
         the hot-reload loop). CanopyDevClient.isCleartextAllowed narrows this further to the
         localhost / RFC-1918 LAN allowlist before any socket opens, so even a mis-baked
         CANOPY_DEV_HOST cannot open a cleartext channel to the internet. This is the platform belt
         to that code brace. The dev client is COMPILED OUT of a release build (#if DEBUG), so in the
         archived binary this exception is inert — no socket ever opens against it. It is kept (rather
         than stripped from the release plist) because NSAllowsLocalNetworking does not weaken the
         production TLS posture (it never permits cleartext to a PUBLIC host) and the host carries a
         single Info.plist across configs.

         If a production endpoint ever genuinely needs a relaxed TLS minimum (e.g. a partner host on
         TLS 1.1), add it as a NARROWLY-SCOPED NSExceptionDomains entry — never NSAllowsArbitraryLoads.
         The structure (documented, empty by default) is:

             <key>NSExceptionDomains</key>
             <dict>
               <key>api.partner.example</key>
               <dict>
                 <key>NSExceptionMinimumTLSVersion</key><string>TLSv1.2</string>
                 <key>NSIncludesSubdomains</key><true/>
               </dict>
             </dict>
    -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsLocalNetworking</key>
        <true/>
    </dict>

    <!-- ===== Launch / scene config ===== -->
    <key>UIApplicationSceneManifest</key>
    <dict>
        <key>UIApplicationSupportsMultipleScenes</key>
        <false/>
        <key>UISceneConfigurations</key>
        <dict>
            <key>UIWindowSceneSessionRoleApplication</key>
            <array>
                <dict>
                    <key>UISceneConfigurationName</key>
                    <string>Default Configuration</string>
                    <key>UISceneDelegateClassName</key>
                    <string>$(PRODUCT_MODULE_NAME).SceneDelegate</string>
                </dict>
            </array>
        </dict>
    </dict>

    <!-- ===== Background modes (Notify scheduling / StoreKit transaction listener) ===== -->
    <key>UIBackgroundModes</key>
    <array>
        <string>remote-notification</string>
    </array>

    <!-- ===== UI ===== -->
    <key>UILaunchStoryboardName</key>
    <string>LaunchScreen</string>
    <key>UIRequiredDeviceCapabilities</key>
    <array>
        <string>arm64</string>
    </array>
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>
    <key>UISupportedInterfaceOrientations~ipad</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationPortraitUpsideDown</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>
    <!-- The host VC owns status-bar appearance (AppShellModule.setStatusBarStyle, §5.3). -->
    <key>UIViewControllerBasedStatusBarAppearance</key>
    <true/>
</dict>
</plist>
