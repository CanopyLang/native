# .remote-build.env — config for remote-build.sh (copy to .remote-build.env and fill in).
# This file is git-ignored. remote-build.sh sources it automatically if present.

# ---- SSH connection to the Mac build host (REQUIRED) --------------------------------------
# user@host of the Mac that has Xcode installed. e.g. ci@192.168.1.50  or  ci@mac.local
MAC_SSH="user@mac.local"

# SSH port (default 22) and an optional identity file. Leave MAC_SSH_KEY empty to use the agent
# / default key. Example: MAC_SSH_KEY="$HOME/.ssh/canopy_mac"
MAC_SSH_PORT="22"
MAC_SSH_KEY=""

# ---- Where the source lands on the Mac ----------------------------------------------------
# An absolute path on the Mac. The harness mirrors host/{ios,shared} under here, preserving the
# ios/ <-> shared/ sibling layout the Xcode project's ../shared/... paths depend on.
REMOTE_DIR="/Users/$(whoami)/canopy-ios-build"

# ---- Simulator + build identifiers (sensible defaults; override only if you must) ---------
SIM_DEVICE="iPhone 15"          # any installed simulator: `xcrun simctl list devices`
CONFIG="Debug"                  # Debug | Release
# These are auto-detected from the generated project if left empty:
WORKSPACE=""                    # e.g. CanopyHost.xcworkspace (after `gen`)
SCHEME=""                       # e.g. CanopyHostApp
APP_BUNDLE_ID="com.canopyhost.app"

# ---- Optional: the Canopy app whose bundle gets shipped into the .app ----------------------
# Absolute path to a built canopy.bundle.js (from `canopy-native build <appdir>`). If empty, the
# `bundle` step is skipped and whatever is already in CanopyHostApp/Resources/ is used (the build
# falls back to an empty placeholder so it never blocks). e.g. /home/quinten/projects/.../build/canopy.bundle.js
CANOPY_BUNDLE=""

# ---- Optional Path-B: vendored Hermes prebuilt (offline / tarball-404 fallback) ------------
# Normally `pod install` downloads the hermes-engine 0.76.9 prebuilt from the network. If that
# tarball 404s (yanked release, air-gapped CI), set this to a path ON THE MAC to a vendored
# Hermes prebuilt tarball; `gen` then exports HERMES_ENGINE_TARBALL_PATH so the podspec uses the
# local prebuilt and never hits the network. See host/ios/Frameworks/VENDOR-LAYOUT.md + the
# README "Path-B" section for how to produce/extract the tarball. Leave empty for the normal path.
# e.g. HERMES_TARBALL="/Users/ci/hermes-prebuilt/hermes-ios-0.76.9.tar.gz"
HERMES_TARBALL=""
