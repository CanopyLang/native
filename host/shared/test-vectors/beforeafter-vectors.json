{
  "$schema": "./beforeafter-vectors.schema.json",
  "version": 1,
  "description": "L-I4 — the platform-neutral test-vector corpus for the C2 before/after WIPE compositor's pure math. The SINGLE source of truth that BOTH hand-written hosts run against: the Android BeforeAfterView (android.graphics.Canvas) and the iOS CanopyBeforeAfterView (UIImageView + CALayer mask, in CanopyHostFabric.mm). Both delegate their numeric rules to the ONE shared header host/shared/cpp/CanopyBeforeAfter.h, so they cannot drift; this corpus pins that math's expected outputs. Unlike the layout corpus there is NO density term — the wipe is a fraction of the view, never a dp — so the SAME unitless fractions + a single nominal width validate both hosts (Android draws in physical pixels, iOS in points; a fraction-of-width is unit-agnostic). Each vector set targets one pure rule: clamp, split column, drag mapping, snap target, snap easing/tween, center-crop cover rect, and the wipeCommit JSON payload (the exact wire bytes, the precise drift this suite removes). A vector green on one host and red on the other is the silent divergence (master plan R5) the suite exists to catch.",
  "units": "unitless fractions (0..1) + a nominal view width/height in the host's own draw units (px on Android, points on iOS); the math is unit-agnostic so the expected value is identical on both.",
  "tolerance": 0.0001,
  "snapDurationSeconds": 0.26,

  "clampVectors": [
    { "id": "clamp-mid",        "input": 0.5,   "expect": 0.5 },
    { "id": "clamp-zero",       "input": 0.0,   "expect": 0.0 },
    { "id": "clamp-one",        "input": 1.0,   "expect": 1.0 },
    { "id": "clamp-below",      "input": -0.3,  "expect": 0.0 },
    { "id": "clamp-above",      "input": 1.7,   "expect": 1.0 },
    { "id": "clamp-tiny-neg",   "input": -0.0001, "expect": 0.0 },
    { "id": "clamp-tiny-over",  "input": 1.0001,  "expect": 1.0 },
    { "id": "clamp-quarter",    "input": 0.25,  "expect": 0.25 },
    { "id": "clamp-third",      "input": 0.3333333, "expect": 0.3333333 }
  ],

  "splitVectors": [
    { "id": "split-half-320",      "wipe": 0.5,   "width": 320, "expect": 160 },
    { "id": "split-zero-320",      "wipe": 0.0,   "width": 320, "expect": 0 },
    { "id": "split-full-320",      "wipe": 1.0,   "width": 320, "expect": 320 },
    { "id": "split-quarter-320",   "wipe": 0.25,  "width": 320, "expect": 80 },
    { "id": "split-third-300",     "wipe": 0.3333333, "width": 300, "expect": 100 },
    { "id": "split-round-up",      "wipe": 0.5,   "width": 99,  "expect": 50 },
    { "id": "split-round-down",    "wipe": 0.4,   "width": 11,  "expect": 4 },
    { "id": "split-over-clamped",  "wipe": 1.3,   "width": 200, "expect": 200 },
    { "id": "split-under-clamped", "wipe": -0.2,  "width": 200, "expect": 0 },
    { "id": "split-odd-width",     "wipe": 0.5,   "width": 641, "expect": 321 }
  ],

  "dragVectors": [
    { "id": "drag-mid",        "x": 160, "width": 320, "expect": 0.5 },
    { "id": "drag-left-edge",  "x": 0,   "width": 320, "expect": 0.0 },
    { "id": "drag-right-edge", "x": 320, "width": 320, "expect": 1.0 },
    { "id": "drag-quarter",    "x": 80,  "width": 320, "expect": 0.25 },
    { "id": "drag-past-right", "x": 400, "width": 320, "expect": 1.0 },
    { "id": "drag-past-left",  "x": -40, "width": 320, "expect": 0.0 },
    { "id": "drag-third",      "x": 100, "width": 300, "expect": 0.3333333 },
    { "id": "drag-zero-width", "x": 50,  "width": 0,   "expect": 0.0 }
  ],

  "snapTargetVectors": [
    { "id": "snap-from-mid",        "wipe": 0.5,  "expect": 0.0 },
    { "id": "snap-from-just-over",  "wipe": 0.51, "expect": 0.0 },
    { "id": "snap-from-just-under", "wipe": 0.49, "expect": 1.0 },
    { "id": "snap-from-left",       "wipe": 0.0,  "expect": 1.0 },
    { "id": "snap-from-right",      "wipe": 1.0,  "expect": 0.0 },
    { "id": "snap-from-quarter",    "wipe": 0.25, "expect": 1.0 },
    { "id": "snap-from-three-q",    "wipe": 0.75, "expect": 0.0 }
  ],

  "snapEasedVectors": [
    { "id": "ease-start",    "t": 0.0,  "expect": 0.0 },
    { "id": "ease-end",      "t": 1.0,  "expect": 1.0 },
    { "id": "ease-quarter",  "t": 0.25, "expect": 0.4375 },
    { "id": "ease-half",     "t": 0.5,  "expect": 0.75 },
    { "id": "ease-three-q",  "t": 0.75, "expect": 0.9375 },
    { "id": "ease-overrun",  "t": 1.5,  "expect": 1.0 },
    { "id": "ease-underrun", "t": -0.2, "expect": 0.0 }
  ],

  "snapTweenVectors": [
    { "id": "tween-start",     "from": 0.5, "to": 1.0, "elapsed": 0.0,  "expect": 0.5 },
    { "id": "tween-end",       "from": 0.5, "to": 1.0, "elapsed": 0.26, "expect": 1.0 },
    { "id": "tween-half-up",   "from": 0.5, "to": 1.0, "elapsed": 0.13, "expect": 0.875 },
    { "id": "tween-half-down", "from": 0.5, "to": 0.0, "elapsed": 0.13, "expect": 0.125 },
    { "id": "tween-overrun",   "from": 0.2, "to": 1.0, "elapsed": 0.40, "expect": 1.0 },
    { "id": "tween-quarter",   "from": 0.0, "to": 1.0, "elapsed": 0.065, "expect": 0.4375 }
  ],

  "coverVectors": [
    {
      "id": "cover-square-into-square",
      "description": "A square bitmap into a square box: scale 1, no offset, exact fill.",
      "viewW": 320, "viewH": 320, "bmpW": 100, "bmpH": 100,
      "expect": { "left": 0, "top": 0, "width": 320, "height": 320 }
    },
    {
      "id": "cover-wide-bmp-into-square",
      "description": "A 200x100 (2:1) bitmap into a 320x320 box: scaled to cover height (×3.2), overflowing width, centered (negative left).",
      "viewW": 320, "viewH": 320, "bmpW": 200, "bmpH": 100,
      "expect": { "left": -160, "top": 0, "width": 640, "height": 320 }
    },
    {
      "id": "cover-tall-bmp-into-square",
      "description": "A 100x200 (1:2) bitmap into a 320x320 box: scaled to cover width (×3.2), overflowing height, centered (negative top).",
      "viewW": 320, "viewH": 320, "bmpW": 100, "bmpH": 200,
      "expect": { "left": 0, "top": -160, "width": 320, "height": 640 }
    },
    {
      "id": "cover-into-wide-box",
      "description": "A square bitmap into a 400x200 box: scaled to cover width (×4), overflowing height, centered.",
      "viewW": 400, "viewH": 200, "bmpW": 100, "bmpH": 100,
      "expect": { "left": 0, "top": -100, "width": 400, "height": 400 }
    },
    {
      "id": "cover-zero-bmp",
      "description": "A degenerate (zero) bitmap yields a zero rect — both hosts skip the draw.",
      "viewW": 320, "viewH": 320, "bmpW": 0, "bmpH": 0,
      "expect": { "left": 0, "top": 0, "width": 0, "height": 0 }
    },
    {
      "id": "cover-zero-view",
      "description": "A not-yet-laid-out (zero) view yields a zero rect.",
      "viewW": 0, "viewH": 0, "bmpW": 100, "bmpH": 100,
      "expect": { "left": 0, "top": 0, "width": 0, "height": 0 }
    }
  ],

  "payloadVectors": [
    { "id": "payload-half",    "fraction": 0.5,       "expect": "{\"fraction\":0.5}" },
    { "id": "payload-zero",    "fraction": 0.0,       "expect": "{\"fraction\":0}" },
    { "id": "payload-one",     "fraction": 1.0,       "expect": "{\"fraction\":1}" },
    { "id": "payload-quarter", "fraction": 0.25,      "expect": "{\"fraction\":0.25}" },
    { "id": "payload-third",   "fraction": 0.3333333, "expect": "{\"fraction\":0.333333}" },
    { "id": "payload-clamped-over",  "fraction": 1.4,  "expect": "{\"fraction\":1}" },
    { "id": "payload-clamped-under", "fraction": -0.2, "expect": "{\"fraction\":0}" }
  ]
}
