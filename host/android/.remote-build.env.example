# .remote-build.env — config for host/android/remote-build.sh (copy to .remote-build.env and fill in).
# This file is git-ignored. remote-build.sh sources it automatically if present.

# ---- SSH connection to the Linux build box (REQUIRED) -------------------------------------
# user@host (or user@IP) of a Linux box you can ssh into. e.g. ubuntu@192.168.1.50
LINUX_SSH="ubuntu@192.168.1.50"
LINUX_SSH_PORT="22"
LINUX_SSH_KEY=""                 # optional identity file, e.g. "$HOME/.ssh/canopy_box"

# ---- Where the source lands on the box ----------------------------------------------------
# Absolute path on the box. host/{android,shared} mirror under here, preserving the
# android/ <-> shared/ sibling layout the CMake ../shared/cpp paths depend on.
REMOTE_DIR="/home/ubuntu/canopy-android-build"

# Where `provision` installs the Android SDK on the box (default: $HOME/android-sdk on the box).
REMOTE_SDK=""

# ---- App + build identifiers (defaults match host/android/app/build.gradle) ---------------
APP_PKG="org.canopy.echo"
APP_ACT="com.canopyhost.MainActivity"
CONFIG="Debug"                   # Debug | Release

# ---- Toolchain versions (MUST match app/build.gradle — change both together) --------------
API_LEVEL="34"
NDK_VER="26.3.11579264"
CMAKE_VER="3.22.1"
BUILD_TOOLS="34.0.0"
SYSIMG="system-images;android-34;google_apis;x86_64"   # use an arm64 image on an arm box
AVD_NAME="canopy_test"

# ---- The Canopy app whose JS bundle gets shipped into the APK ------------------------------
# Absolute path to a built canopy.bundle.js (from `canopy-native build <appdir>`), built LOCALLY
# so the box needs no Canopy/Haskell toolchain. If empty, whatever is in app/src/main/assets/ is used.
# e.g. /home/quinten/projects/canopy/native/examples/counter/build/canopy.bundle.js
CANOPY_BUNDLE=""
