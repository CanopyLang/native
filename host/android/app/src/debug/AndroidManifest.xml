<?xml version="1.0" encoding="utf-8"?>
<!--
  AndroidManifest.xml (DEBUG variant overlay) — DEV-6.

  Merged into the main manifest for the DEBUG build ONLY (this file lives under src/debug). It:
    1. points the application at the debug network_security_config so cleartext ws:// to the dev
       loop's localhost/LAN endpoints is permitted (a release build, which never sees this overlay,
       keeps the platform default — cleartext OFF on API 28+);
    2. registers CanopyDevBootstrap, a no-UI ContentProvider that Android instantiates at process
       start, which auto-starts the CanopyDevClient WebSocket. A ContentProvider is the standard
       zero-dependency early-init hook (it runs before Application.onCreate), so the dev loop wires
       itself up with NO edit to the production MainActivity / Application.

  Both additions are debug-only by construction (src/debug overlay) — the shipped release APK
  carries neither the cleartext config nor the bootstrap provider.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:networkSecurityConfig="@xml/network_security_config">

        <!-- Auto-start the dev client at process boot. exported=false, no permission, debug-only.
             A unique authority keyed off the applicationId avoids a collision if the app is
             installed alongside another canopy build. -->
        <provider
            android:name="com.canopyhost.CanopyDevBootstrap"
            android:authorities="${applicationId}.canopydevbootstrap"
            android:exported="false"
            android:enabled="true" />
    </application>
</manifest>
