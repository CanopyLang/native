<?xml version="1.0" encoding="utf-8"?>
<!--
  network_security_config.xml (DEBUG variant only) — scopes cleartext (non-TLS) traffic to the
  dev loop's localhost / private-LAN endpoints ONLY. DEV-6: the dev server speaks ws:// with no
  TLS, so the debug build must permit cleartext to it — but ONLY to a machine on the same desk/LAN,
  never the public internet. This is the platform-layer half of CanopyDevClient.isCleartextAllowed.

  A RELEASE build does NOT include this file (it lives in src/debug/res), and its manifest has no
  android:usesCleartextTraffic — so the shipped APK keeps the platform default (cleartext OFF on
  API 28+). The dev cleartext path exists only in debug.

  NOTE: domain-config entries cannot express CIDR ranges, only literal hosts/suffixes. We list the
  loopback + the emulator host alias explicitly; for a real LAN box the app-wide debug default
  (cleartextTrafficPermitted below) plus the runtime isCleartextAllowed() RFC-1918 check cover the
  192.168/10/172.16 addresses a developer dials.
-->
<network-security-config>
    <!-- Debug default: cleartext permitted (the dev loop is debug-only). The runtime allowlist in
         CanopyDevClient.isCleartextAllowed() narrows this to localhost/LAN before any socket opens. -->
    <base-config cleartextTrafficPermitted="true" />

    <!-- Belt-and-braces: pin the loopback + emulator-alias endpoints explicitly so they are always
         reachable regardless of the base default. -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">10.0.3.2</domain>
    </domain-config>
</network-security-config>
