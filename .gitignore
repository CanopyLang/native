# =============================================================================
# canopy/native — .gitignore
# Keep: all source, the vendored Hermes/ONNX prebuilts (host/android/vendor/**),
# the gradle wrapper, and the DEV keystore (host/android/canopy-release.jks — its
# password is a public dev fallback in app/build.gradle; production signing comes
# from CANOPY_STORE_FILE gradle properties / secrets, never the repo).
# Ignore: every regenerable build artifact, machine-specific config, and secrets.
# =============================================================================

# ---- Canopy compiler output / cache (regenerated by `canopy make` / `canopy-native build`) ----
canopy-stuff/
artifacts.dat
*.elco
package/output/

# ---- JS bundles are build output (integrity-checked, never committed; rebuild with canopy-native build) ----
**/canopy.bundle.js
**/canopy.bundle.js.map
**/canopy.manifest.json

# ---- Generic build dirs ----
**/build/
**/.cxx/
host/shared/build-android/
host/shared/build-host/

# ---- Haskell / Stack ----
**/.stack-work/
*.hi
*.o

# ---- Android / Gradle ----
**/.gradle/
**/local.properties
**/captures/
*.iml

# ---- iOS / Xcode (generated; pods + frameworks are fetched/vendored by remote-build.sh) ----
**/DerivedData/
**/Pods/
host/ios/**/*.xcodeproj/
host/ios/**/*.xcworkspace/
host/ios/Podfile.lock
host/ios/node_modules/
host/ios/Frameworks/*.xcframework/
host/ios/Frameworks/*.framework/

# ---- Remote build harness: secrets (the SSH target / IP lives here) + pulled artifacts ----
**/.remote-build.env
**/.remote.env
**/remote-artifacts/

# ---- Production signing secrets (the dev keystore IS committed; real ones are not) ----
keystore.properties
*.p12
*.pem
release.keystore

# ---- Node ----
node_modules/

# ---- Example local-dev accommodations (regenerated; see examples/counter/README.md) ----
examples/*/external/

# ---- Editors / OS ----
.DS_Store
*.swp
.idea/
.vscode/
*.log
